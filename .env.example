# Copy to .env and adjust for local development:

# Event Gateway -> Account Service (use http://account-service:8001 in Docker Compose)
ACCOUNT_SERVICE_URL=http://localhost:8001

# Resiliency (Gateway -> Account Service HTTP client)
ACCOUNT_REQUEST_TIMEOUT=2
ACCOUNT_MAX_RETRIES=3
ACCOUNT_BACKOFF_BASE=0.1

# SQLite databases (one file per service; paths are relative to the process working directory)
GATEWAY_DATABASE_URL=sqlite:///./gateway.db
ACCOUNT_DATABASE_URL=sqlite:///./account.db
